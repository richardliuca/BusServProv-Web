# Copy to .env for local tooling outside Docker (optional).

# --- PostgreSQL (one server, two databases: `temporal` + `app`) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=temporal
# App database (created by infra/postgres/init-app-db.sql on first init)
APP_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app

# --- Temporal (gRPC) ---
# When false, the Nest API skips the Temporal client; POST /api/booking-requests returns 503.
TEMPORAL_ENABLED=true
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=booking
TEMPORAL_CONNECT_ATTEMPTS=40
TEMPORAL_CONNECT_DELAY_MS=2000

# --- Next.js SSR (container → Nest; not exposed to browsers) ---
INTERNAL_API_URL=http://api:3001
